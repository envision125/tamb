            >Terms of Service</a
          >
          <a href="#" class="hover:text-white transition-colors"
            >Cookie Policy</a
          >
        </div> -->
    </div>
  </div>
</footer>

<style>
  /* Smooth transitions for better UX */
  footer a {
    transition: color 0.2s ease-in-out;
  }

  /* Focus styles for accessibility */
  footer a:focus {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  /* Mobile optimizations */
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    footer {
      text-align: center;
    }

    .grid > div {
      margin-bottom: 2rem;
    }

    .grid > div:last-child {
      margin-bottom: 0;
    }
  }
</style>
