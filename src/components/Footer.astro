---
// Footer component for J & MC Janitorial

import { Image } from "astro:assets";
import logo from "../tabpic.jpeg";
const contactInfo = {
  phone: "(510) 434-9454",
  email: "tortasahogadasmibarrio@gmail.com",
  address: "Okaland, CA",
};

const yelplink = "https://www.yelp.com/biz/tortas-ahogadas-mi-barrio-oakland";
const instalink = "https://www.instagram.com/tortasahogadasmibarrio/";
---

<footer class="bg-white  text-white">
  <!-- Main Footer Content -->
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      <!-- Company Info -->
      <div class="lg:col-span-2">
        <div class="mb-6">
          <div class="mb-4 flex justify-center">
            <Image
              src={logo}
              alt="J & MC Commercial Janitorial Services."
              class="w-40 h-40 rounded-lg mb-4"
            />
          </div>
          <p class="mb-4 leading-relaxed">
            Providing premium cleaning services for over 15 years. Trusted by
            businesses across the peninsula for our excellence and reliability.
          </p>
          <!-- <div class="flex items-center space-x-2 text-sm text-gray-400">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Serving peninsula!</span>
          </div> -->
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-lg text-red-700 font-semibold mb-4">Menu</h3>
        <ul class="space-y-2">
          <li>
            <a href="#" class="text-sky-900 hover:text-yellow-500 transition-colors"
              >Home</a
